# ═══════════════════════════════════════════════════════
# HOFIZ BOT — Muhit O'zgaruvchilari
# ═══════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════
# RAILWAY DEPLOY eslatmasi:
#   DATABASE_URL va REDIS_URL ni Railway o'zi inject qiladi —
#   qo'lda kiritish shart emas. Faqat quyidagilarni kiriting:
#   BOT_TOKEN, ADMIN_IDS, API_SECRET_KEY, AUDD_API_KEY, GENIUS_API_KEY
#   Bot xizmatida: BOT_MODE=polling, API_BASE_URL=https://api-xxx.railway.app
# ═══════════════════════════════════════════════════════

# ---- Telegram Bot ----
BOT_TOKEN=your_bot_token_here
BOT_WEBHOOK_URL=https://your-domain.com/webhook
BOT_WEBHOOK_SECRET=your_webhook_secret_here
BOT_MODE=polling
# Railway uchun: polling (webhook uchun domen kerak emas)

# ---- Admin ----
ADMIN_IDS=123456789,987654321

# ---- Database ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hofiz_bot
DB_USER=hofiz
DB_PASSWORD=your_strong_password_here

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- Media Download API ----
API_BASE_URL=http://api:8000
API_SECRET_KEY=your_api_secret_key_here

# ---- AudD (Musiqa Aniqlash) ----
AUDD_API_KEY=your_audd_api_key_here

# ---- Genius (Qo'shiq Matni) ----
GENIUS_API_KEY=your_genius_api_key_here

# ---- Yandex Object Storage ----
YANDEX_STORAGE_KEY=your_yandex_key_here
YANDEX_STORAGE_SECRET=your_yandex_secret_here
YANDEX_STORAGE_BUCKET=hofiz-media
YANDEX_STORAGE_REGION=ru-central1

# ---- Backup ----
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30
